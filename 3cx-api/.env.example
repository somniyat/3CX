# ─── Serveur ─────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── Authentification API ────────────────────────────────────
# Changer impérativement en production !
API_KEY=changez-moi-en-production

# ─── Credentials 3CX (optionnel, fallback si pas dans les headers) ──
# THREECX_BASE_URL=https://your-server.3cx.ch:5001
# THREECX_CLIENT_ID=your-client-id
# THREECX_CLIENT_SECRET=your-client-secret

# ─── CORS ────────────────────────────────────────────────────
# Origines autorisées séparées par des virgules
CORS_ORIGINS=http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
